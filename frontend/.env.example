# API en AWS (producción). Obligatorio para que el front consuma el backend desplegado.
# Front en local (npm run dev) usa esta URL; CORS del API debe incluir http://localhost:5173.
VITE_API_BASE_URL=https://energymonitor.click/api

# Alternativa directa API Gateway (si no usas CloudFront):
# VITE_API_BASE_URL=https://626lq125eh.execute-api.us-east-1.amazonaws.com/api

# Solo para depurar API Nest en tu máquina:
# VITE_API_BASE_URL=http://localhost:4000/api

# Opcional: timeouts Axios (ms). Por defecto 60000 global y 120000 en /auth/* (cold Lambda en VPC).
# VITE_API_TIMEOUT_MS=60000
# VITE_API_AUTH_TIMEOUT_MS=120000

VITE_AUTH_MODE=microsoft
VITE_MICROSOFT_CLIENT_ID=
VITE_MICROSOFT_TENANT_ID=
VITE_GOOGLE_CLIENT_ID=
