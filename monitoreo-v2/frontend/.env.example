VITE_MICROSOFT_CLIENT_ID=
VITE_MICROSOFT_TENANT_ID=
VITE_GOOGLE_CLIENT_ID=
# Relativo: Vite reenvía /api a http://localhost:4000 (vite.config.ts). Requiere backend Nest en :4000.
VITE_API_BASE_URL=/api
# Si ves 404 en /api con el dev server, comprueba: (1) backend en :4000, (2) `npm run dev` desde monitoreo-v2/frontend (no preview sin proxy ni otro proceso en :5173).
# Alternativa sin proxy (CORS ya permite :5173): VITE_API_BASE_URL=http://localhost:4000/api
# Opcional: orígenes extra para CSP connect-src (coma). Ej: otro dominio API o staging.
# VITE_CSP_EXTRA_CONNECT=https://plataforma.ejemplo.com
# Emergencia: omitir meta CSP en build (no usar salvo rollback).
# VITE_CSP_DISABLED=true
